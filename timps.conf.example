# timps configuration (plain key = value, replaces libconfig)
# Copy to /etc/timps.conf and adjust for your camera.

# ---- general ----
general.loglevel            = 2      # 0=err 1=warn 2=info 3=debug
general.syslog              = 1      # 1 = also log to syslog so messages show up
                                     #     in `logread` (the init script backgrounds
                                     #     timpsd, so its stderr is discarded);
                                     #     0 = stderr only (foreground / host sim)
general.imp_polling_timeout = 500    # ms, encoder poll timeout
general.osd_pool_size       = 1000   # KB, IMP OSD pool

# ---- sensor ----
# OPTIONAL: leave any of these out (or empty/0) and timps auto-detects it from
# the Ingenic kernel sensor registry /proc/jz/sensor/sensor0/ (name/i2c_addr/
# width/height/max_fps), like raptor/prudynt - so one config works across
# cameras. A value set here always wins; a safe fallback applies if neither the
# config nor the registry has it (host sim / T40/T41 have no registry).
sensor.model    = gc2053
sensor.i2c_addr = 0x37
sensor.fps      = 25
sensor.width    = 1920
sensor.height   = 1080

# ---- image / ISP tuning (all 0..255 unless noted; 128 = neutral) ----
image.brightness             = 128
image.contrast               = 128
image.saturation             = 128
image.sharpness              = 128
image.hue                    = 128
image.hflip                  = 0
image.vflip                  = 0
image.anti_flicker           = 2     # 0 off, 1 = 50Hz, 2 = 60Hz
image.running_mode           = 0     # 0 day, 1 night
image.ae_compensation        = 128
image.max_again              = 160
image.max_dgain              = 80
image.sinter_strength        = 128   # spatial NR
image.temper_strength        = 128   # temporal NR
image.dpc_strength           = 128
image.defog_strength         = 128
image.drc_strength           = 128
image.highlight_depress      = 0
image.backlight_compensation = 0
image.core_wb_mode           = 0     # 0 auto
image.wb_rgain               = 0
image.wb_bgain               = 0

# ---- SECURITY --------------------------------------------------------------
# Authentication is OFF only while user/pass are empty. Set credentials to lock
# the device: RTSP then requires Digest auth, HTTP requires Basic auth. Nothing
# can be viewed or controlled without them. Strongly recommended.
# NOTE: HTTP Basic sends credentials base64-encoded; use it on a trusted LAN or
# behind a TLS reverse proxy.

# ---- RTSP server (video + audio, no live555) ----
rtsp.enabled = 1
rtsp.port    = 554
rtsp.user    =            # set to enable RTSP Digest auth
rtsp.pass    =

# ---- HTTP preview (fMP4 + JPEG/MJPEG) ----
http.enabled     = 1
http.port        = 8880
http.preview_chn = 1
http.user        =        # set to enable HTTP Basic auth (empty = reuse rtsp.user/pass)
http.pass        =
#
# Token auth (USE_CONTROL builds). /control, /events and the HTTP media
# endpoints (/stream.mp4, /stream.mjpeg, /snapshot.jpg, incl. ?chn=N) accept,
# besides localhost and HTTP Basic, a token sent as
#     X-Timps-Token: <token>          header (preferred), or
#     ?token=<token>                  query string - the only form <img>/
#                                     <video src>/EventSource can use
#                                     (CAUTION: query strings can end up in
#                                     proxy/access logs; fine on a LAN)
# Two tokens are valid:
#   1. a random PER-BOOT token, regenerated on every start and written to
#      http.token_file (mode 0640) so a local privileged helper (the thingino
#      WebUI) can read it and let the browser talk to :8880 directly;
#   2. the optional PERSISTENT secret http.token below - a stable credential
#      for remote automation. It is NEVER written to http.token_file.
# The token unlocks /control + /events + HTTP media VIEWING - never RTSP,
# and nothing else on the port. Like Basic auth, tokens travel in cleartext:
# put TLS in front before exposing the port to the internet.
http.token       =
http.token_file  = /run/timps.token

# ---- optional TLS: HTTPS + RTSPS (USE_TLS builds, mbedTLS) ----
# Only present when timps is built with mbedTLS (BR2_PACKAGE_MBEDTLS). Without
# it these keys are parsed but ignored and timps stays plain HTTP/RTSP.
# Uses thingino's httpd cert (mbedtls-certgen); S95timps generates it on first
# boot if missing. NOTE: with a SELF-SIGNED cert the browser blocks the WebUI's
# cross-origin media fetches to :8880 until you visit https://<ip>:8880/ once
# and trust it - so https is opt-in, not on by default.
# http.https    = 1                       # serve the HTTP port over TLS
http.tls_cert   = /etc/ssl/certs/httpd.crt
http.tls_key    = /etc/ssl/private/httpd.key
# rtsp.tls      = 1                       # additionally run an RTSPS listener
# rtsp.tls_port = 322                     # RTSPS port

# ---- SRT output (USE_SRT builds, libsrt) ----
# MPEG-TS over SRT in listener mode: ffplay srt://<ip>:9000
srt.enabled    = 1
srt.port       = 9000
# srt.channel    = 0
# srt.latency_ms = 120
# srt.streamid   =                        # optional required STREAMID
# srt.passphrase =                        # optional AES passphrase

# ---- /events push stream (SSE, USE_CONTROL builds) ----
# GET /events on the HTTP port is a long-lived text/event-stream that PUSHES
# JSON state as it changes instead of being polled: "motion" (grid cells),
# "daynight" (mode/brightness/gain) and a periodic "stats" event (clients,
# per-stream fps, uptime). ?stream=motion,daynight,stats filters the types.
# Access rules are the /control ones (localhost / token / Basic); browsers
# use ?token= because EventSource cannot send headers (query strings can end
# up in logs - accepted on the LAN, the token never unlocks RTSP).
# Startup settings, deliberately not settable via /control.
events.enabled     = 1
events.stats_ms    = 2000    # "stats" event period in ms (0 = no stats events)
events.max_clients = 8       # concurrent /events connections (above -> 503)

# ---- JPEG / MJPEG stream (the old streamer's "stream2") ----
# HTTP endpoints:  /snapshot.jpg (single frame)   /stream.mjpeg (motion JPEG)
jpeg.enabled       = 1
jpeg.width         = 640
jpeg.height        = 360
jpeg.quality       = 75          # 1..100
jpeg.fps           = 5           # max MJPEG frame rate
jpeg.imp_chn       = 2           # JPEG encoder channel
# jpeg.snapshot_path = /tmp/snapshot.jpg   # also write a periodic file snapshot
#
# Additional JPEG resolutions: an extra JPEG encoder can piggyback on any
# video stream. It shares that stream's framesource (no extra rmem, unlike a
# second dedicated jpeg channel) and delivers JPEGs at the stream resolution.
# Fetch with:  /snapshot.jpg?chn=0   /stream.mjpeg?chn=1   (no ?chn= = jpeg.*)
# On-demand like everything else: no CPU/encoder cost until a client fetches.
# The thingino WebUI previews fetch /stream.mjpeg?chn=N + /snapshot.jpg?chn=N
# directly from this port (with ?token=, see above - no proxy CGIs), so keep
# these enabled when timps runs under thingino.
video0.jpeg         = true      # JPEG at video0 resolution (e.g. 1920x1080)
video0.jpeg_quality = 75
video0.jpeg_fps     = 5
video0.jpeg_chn     = 3         # unique IMP encoder channel
video1.jpeg         = true      # JPEG at video1 resolution (e.g. 640x360)
video1.jpeg_chn     = 4

# ---- main video stream (channel 0) ----
video0.enabled   = 1
video0.codec     = h264      # h264 | h265
video0.width     = 1920
video0.height    = 1080
video0.fps       = 25
video0.bitrate   = 3000      # kbps
video0.rc_mode   = cbr       # cbr | vbr | fixqp | smart | capped_vbr | capped_quality
video0.gop       = 50
video0.max_gop   = 60
video0.profile   = 2         # 0 baseline 1 main 2 high
video0.qp        = 35
video0.min_qp    = 20
video0.max_qp    = 45
video0.rotation  = 0         # 0 | 90 | 270  (SoC dependent)
video0.buffers   = 2
video0.rtsp_path = /ch0
video0.imp_chn   = 0

# ---- sub video stream (channel 1) ----
video1.enabled   = 1
video1.codec     = h264
video1.width     = 640
video1.height    = 360
video1.fps       = 25
video1.bitrate   = 512
video1.rc_mode   = cbr
video1.gop       = 50
video1.profile   = 2
video1.rotation  = 0
video1.rtsp_path = /ch1
video1.imp_chn   = 1

# ---- audio ----
# Mic (AI) processing keys marked "live" apply immediately via /control; which
# ones a given SoC supports is reported in caps.audio (alc_gain only on
# T21/T31/C100). codec/samplerate/bitrate/channels are encoder-init attributes:
# they persist and take effect on restart. The SoC mic is mono; channels = 2
# (or force_stereo = 1) enables SIMULATED stereo: the mono capture is duplicated
# to L=R and encoded as 2-channel dual-mono AAC for clients that require a
# stereo track. AAC only - G.711 (pcmu/pcma) has no standard stereo and stays
# mono. timps has no audio-OUT (AO) pipeline, so the spk_* speaker keys are
# stored for the WebUI but ignored (logged as such).
audio.enabled            = 1
audio.codec              = aac    # aac | pcmu | pcma | none  (persist + restart)
audio.samplerate         = 16000  # 8000 | 16000              (persist + restart)
audio.channels           = 1      # 1 mono | 2 = simulated stereo (dual-mono),
                                  # AAC only               (persist + restart)
audio.bitrate            = 32     # kbps, aac                 (persist + restart)
audio.volume             = 80     # live — IMP_AI_SetVol
audio.gain               = 25     # live — IMP_AI_SetGain
audio.alc_gain           = 0      # live — IMP_AI_SetAlcGain PGA 0..7 (T21/T31/C100)
audio.high_pass          = 0      # live — high-pass filter on/off
audio.agc                = 0      # live — automatic gain control on/off
audio.agc_target_dbfs    = 10     # live — AGC target level 0..31
audio.agc_compression_db = 0      # live — AGC compression gain 0..90
audio.ns                 = 0      # live — noise suppression 0 off, 1..3
audio.mute               = 0      # live — mic mute (1 = drop captured frames,
                                  #        clients receive no audio; no restart)
# speaker: no AO path in timps (stored for the WebUI only, IGNORED - the
# daemon logs "no speaker/AO pipeline" when set via /control)
# audio.spk_enabled  = 0
# audio.spk_volume   = 80
# audio.spk_gain     = 25
# alias for audio.channels = 2: simulated stereo (dual-mono), AAC only,
# applies on restart
# audio.force_stereo = 0

# ---- OSD (up to 8 overlays PER video stream; own TrueType rasterizer) ----
osd.enabled        = 1
osd.monitor_stream = 0                        # stream whose fps feeds {fps}
osd.font_path      = /usr/share/fonts/default.ttf   # default TTF; empty = bitmap font
osd.vars_file      = /tmp/timps_osd.vars                  # custom placeholder source
osd.supersample    = 2                        # TTF rasterizer AA: samples/axis/pixel
                                               # (1-4). 2 = default, visually identical
                                               # to 4 at typical OSD sizes but ~2x
                                               # cheaper to render; 4 = old default,
                                               # higher CPU; 1 = cheapest, visibly
                                               # rougher edges. No effect on the
                                               # embedded bitmap font (font_path empty).
#
# Every video stream carries its OWN independent overlay set.
# Canonical keys:  osd<S>.<N>.<field>  = stream S (0 = main, 1 = sub), item N
#                  e.g. osd0.0.text (stream 0 item 0), osd1.2.x (stream 1 item 2)
# Legacy keys:     osd<N>.<field>  (pre-per-stream) still load and apply the
#                  item to EVERY stream, so old configs keep looking the same.
# Each item is either type=text or type=logo.
# Text placeholders:
#   time:    strftime tokens, e.g. %Y-%m-%d %H:%M:%S  %F %T
#   builtin: {hostname} {ip} {mac} {fps} {uptime}
#   custom:  any {name} is read from osd.vars_file (key = value lines),
#            so a script can write e.g.  site = Frontdoor  into that file.
# Text outline (readability stroke, drawn under the fill):
#   outline       = width in px (0 = off, default)
#   outline_color = 0xAARRGGBB (default 0xFF000000 black)
# font_size is an ABSOLUTE pixel height and is NOT auto-scaled per stream, so
# set the sub-stream (osd1.*) size directly for legibility - a small sub-stream
# needs a proportionally similar px size, not a smaller number.
#
osd0.0.enabled   = 1
osd0.0.type      = text
osd0.0.text      = {hostname}  %Y-%m-%d %H:%M:%S
osd0.0.x         = 16
osd0.0.y         = 16
osd0.0.font_size = 32
osd0.0.color     = 0xFFFFFFFF                 # ARGB
osd0.0.transparency = 255
osd0.0.outline       = 1                      # 1 px black stroke (on by default)
osd0.0.outline_color = 0xFF000000
# osd0.0.font_path =                          # optional per-item TTF override

osd0.1.enabled   = 1
osd0.1.type      = text
osd0.1.text      = {fps} fps  {ip}
osd0.1.x         = 16
osd0.1.y         = 56
osd0.1.font_size = 24
osd0.1.color     = 0xFFFFFF00

# substream: its own set, e.g. just a timestamp
osd1.0.enabled   = 1
osd1.0.type      = text
osd1.0.text      = %Y-%m-%d %H:%M:%S
osd1.0.x         = 16
osd1.0.y         = 16
osd1.0.font_size = 24                         # absolute px on the sub-stream
osd1.0.outline       = 1
osd1.0.outline_color = 0xFF000000

# osd0.2.enabled   = 1
# osd0.2.type      = logo
# osd0.2.logo      = /etc/logo.bgra          # raw BGRA pixels
# osd0.2.logo_w    = 100
# osd0.2.logo_h    = 30
# osd0.2.x         = 1780
# osd0.2.y         = 16
# osd0.2.transparency = 200

# ---- privacy masks (solid cover rectangles) ----
# Up to MS_MAX_PRIVACY (4) rectangles per video stream, drawn as IMP OSD cover
# regions to black out sensitive areas. Applied live via /control and here.
# Keys: privacy<S>.<N>.{enabled,x,y,w,h,color}. x/y/w/h in the stream's pixels;
# color is 0xAARRGGBB (default opaque black). caps.privacy in GET /control
# reports {available, max_regions}.
# privacy0.0.enabled = 1
# privacy0.0.x       = 100
# privacy0.0.y       = 80
# privacy0.0.w       = 320
# privacy0.0.h       = 180
# privacy0.0.color   = 0xFF000000

# ---- local recording (fragmented MP4 to SD, like raptor's RMR) ----
# Records one video stream to <dir>/<hostname>/records/<name>.mp4, rotating
# every segment_s at a keyframe. mode: continuous | motion (record around
# motion with pre/post roll; needs motion.enabled). Old segments are pruned to
# keep min_free_mb free. The /control "record" action (WebUI record button)
# is a manual start/stop override on top of this.
# record.enabled     = 1
# record.channel      = 0
# record.mode         = motion          # or: continuous
# record.dir          = /mnt/mmcblk0p1  # SD mount
# record.name         = %Y%m%d/%H/%Y%m%dT%H%M%S   # strftime, under <host>/records/
# record.segment_s    = 60
# record.pre_roll_s   = 3
# record.post_roll_s  = 10
# record.min_free_mb  = 200
# record.audio        = 1               # mux AAC audio when available

# ---- native timelapse (periodic JPEG snapshots) ----
# Every interval_s the newest JPEG frame is written to
# <dir>/<hostname>/timelapses/<name>.jpg (mkdir -p, atomic tmp+rename).
# channel picks the video stream whose piggyback JPEG encoder is captured
# (videoN.jpeg = true; falls back to the dedicated jpeg.* channel). dir may be
# ANY writable path (SD, NFS, ...). Shots older than keep_days are pruned
# (0 = keep forever). All keys are live via /control ("timelapse" section);
# the control-bar timelapse button toggles timelapse.enabled.
# timelapse.enabled    = 1
# timelapse.channel    = 0
# timelapse.dir        = /mnt/mmcblk0p1
# timelapse.name       = %Y%m%d/%H/%Y%m%dT%H%M%S   # strftime, .jpg appended
# timelapse.interval_s = 60
# timelapse.keep_days  = 7

# ---- motion detection (Ingenic IMP_IVS) ----
# The detection area is a cols x rows GRID over the monitor stream's frame;
# each cell reports motion separately (GET /control exposes the live per-cell
# state, the thingino WebUI draws it as a preview overlay). cols*rows is
# clamped to the SDK's ROI budget (IMP_IVS_MOVE_MAX_ROI_CNT: 52 on most SDKs,
# 4 on the old T10/T20 3.9.0 SDK; reported as caps.motion.max_cells).
# enabled/sensitivity/cols/rows/monitor_stream are live via /control;
# cooldown_ms and on_motion are config-file only (on_motion runs through
# system() and is deliberately not settable over HTTP).
motion.enabled        = 0
motion.monitor_stream = 0
motion.sensitivity    = 128           # 0..255 (mapped to IMP 0..4)
motion.cols           = 5             # grid columns
motion.rows           = 5             # grid rows
motion.cooldown_ms    = 5000
motion.hold_ms        = 800           # keep a cell lit this long (ms) after its
                                      # last hit so the grid overlay reliably
                                      # shows single-frame motion (0 = raw)
motion.skip_frames    = 5             # analyse every Nth frame: higher = cheaper
                                      # + more latency, lower (2-3) = snappier
# motion.on_motion    = /etc/scripts/on_motion.sh

# ---- automatic day/night (needs timps built with USE_DAYNIGHT) ----
# timps samples the ISP exposure state and switches via the board's daynight
# script (ircut / IR LEDs / color). The decision is GAIN-based like
# prudynt/raptor: total_gain is the combined sensor+ISP gain in the IMP
# [24.8] linear scale (256 = 1x). Lower gain = brighter scene = day.
# Day when total_gain < total_gain_day_threshold, night when
# total_gain > total_gain_night_threshold; the big gap between the two is
# the hysteresis dead-zone (no flapping in between). threshold_low/high are
# the brightness-% fallback (daynightd semantics), used only when the ISP
# proc file exposes no gain fields.
daynight.enabled        = 1                    # 0 = manual mode (WebUI/`/control` only)
daynight.total_gain_day_threshold   = 300      # (in night) gain below -> day
daynight.total_gain_night_threshold = 3000     # (in day) gain above -> night
# adaptive night baseline (raptor-style, robust against IR flicker): a while
# after switching to night (IR LEDs settled) the current gain is sampled as the
# baseline, and night->day then triggers when gain < day_gain_pct% of it instead
# of the fixed day threshold. day_gain_pct = 0 disables (fixed threshold only).
daynight.day_gain_pct     = 60                 # night->day at this % of baseline
daynight.baseline_delay_s = 30                 # wait this long in night to sample it
daynight.threshold_low  = 25                   # fallback %: below this (in day) -> night
daynight.threshold_high = 75                   # fallback %: above this (in night) -> day
daynight.hysteresis     = 0.1                  # fallback band factor, initial decision
daynight.interval_ms    = 500                  # sample interval
daynight.transition_s   = 5                    # min seconds between switches
daynight.switch_cmd     = daynight             # run as "<cmd> day|night"
daynight.isp_path       = /proc/jz/isp/isp-m0  # ISP exposure proc file

# ---- on-demand ----
# All streams (H264/H265, audio, JPEG/MJPEG) are only captured and encoded
# while at least one client is connected. No CPU is spent when nobody watches.
# This is automatic; there is nothing to configure.

# ---- simulation backend (host testing only, ignored on device) ----
# sim.video0 = /tmp/ch0.h264
# sim.video1 = /tmp/ch1.h264
# sim.audio  = /tmp/aud.aac
# sim.jpeg   = /tmp/snap.jpg
